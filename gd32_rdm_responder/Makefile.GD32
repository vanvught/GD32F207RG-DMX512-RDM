DEFINES=RDM_RESPONDER 
DEFINES+=CONFIG_RDM_ENABLE_SELF_TEST
DEFINES+=CONFIG_RDM_ENABLE_MANUFACTURER_PIDS
#DEFINES+=CONFIG_RDM_ENABLE_CONFIG_PIDS

DEFINES+=CONFIG_PIXELDMX_MAX_PORTS=1
DEFINES+=OUTPUT_DMX_PIXEL 

DEFINES+=DISPLAY_UDF

DEFINES+=DISABLE_FS

DEFINES+=NDEBUG

SRCDIR=firmware lib

include ../firmware-template-gd32/Rules.mk

prerequisites:
	@echo "constexpr uint32_t DEVICE_SOFTWARE_VERSION_ID="$(shell date "+%s")";" > ./include/software_version_id.h
